{
  "env": {
    "node": true,
    "mocha": true
  },
  "extends": "airbnb-base",
  "plugins": [
    "chai-friendly"
  ],
  "rules": {
    "brace-style": [2, "stroustrup"],
    "comma-dangle": 0,
    "consistent-return": 0,
    "max-len": 0,
    "new-cap": 0,
    "no-console": 0,
    "no-multi-spaces": 0,
    "no-param-reassign": 0,
    "no-restricted-syntax": 0,
    "no-unused-expressions": 0,
    "padded-blocks": [2, "always"],
    "chai-friendly/no-unused-expressions": 2,
    "react/destructuring-assignment": 0
  }
}