{
  "env": {
    "node": true
  },
  "extends": [
    "airbnb-base",
    "plugin:@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "plugins": [
    "@typescript-eslint"
  ],
  "parserOptions": {
    "ecmaVersion": 2023,
    "sourceType": "module"
  },
  "rules": {
    "@typescript-eslint/no-var-requires": "off",
    "brace-style": [2, "stroustrup"],
    "comma-dangle": 0,
    "consistent-return": 0,
    "max-len": 0,
    "new-cap": 0,
    "no-console": 0,
    "no-multi-spaces": 0,
    "no-param-reassign": 0,
    "no-restricted-syntax": 0,
    "no-unused-expressions": 0,
    "padded-blocks": [2, "always"]
  }
}
