{
  "name": "api-demo",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "license": "ISC",
  "author": "Justin Levett-Yeats",
  "engines": {
    "npm": ">=11.6.0 <12.0.0",
    "node": ">=24.8.0 <26.0.0"
  },
  "type": "module",
  "main": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:justinl-y/api-demo.git"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && swc -D src -d dist --strip-leading-paths",
    "api-build": "docker compose -p api -f docker-compose-local.yml build --no-cache",
    "api-up": "docker compose -p api -f docker-compose-local.yml up",
    "api-down": "docker compose -p api -f docker-compose-local.yml down -v",
    "ci-build-service": "docker compose -p ci -f docker-compose-ci.yml build --no-cache",
    "ci-down": "docker compose -p ci -f docker-compose-ci.yml down -v",
    "ci-build": "printf \"db api test\" | tr ' ' '\n' | xargs -n1 -P3 -I{} npm run ci-build-service {}",
    "ci-up": "TEST_CASE=${TEST_CASE} docker compose -p ci -f docker-compose-ci.yml up",
    "lint": "eslint --config eslint.config.mjs",
    "lint-fix": "eslint --fix \"**/*.{ts}\"",
    "precommit-lint": "lint-staged",
    "precommit-msg": "echo 'Running pre-commit checks...' && exit 0"
  },
  "pre-commit": [
    "precommit-msg",
    "precommit-lint"
  ],
  "lint-staged": {
    "**/*.js": "eslint --config eslint.config.mjs",
    "**/*.ts": "eslint --config eslint.config.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.899.0",
    "@fastify/accepts": "^5.0.3",
    "@fastify/compress": "^8.1.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@jordanarseno/node-postgres-named": "^3.0.1",
    "@sentry/node": "^10.17.0",
    "@sentry/profiling-node": "^10.17.0",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "lodash": "^4.17.21",
    "pg": "^8.16.3",
    "restify-errors": "^8.0.2"
  },
  "devDependencies": {
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@tsconfig/node24": "^24.0.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.6.1",
    "eslint": "^9.36.0",
    "lint-staged": "^13.0.0",
    "neostandard": "^0.12.2",
    "pre-commit": "^1.2.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
